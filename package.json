    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv-cli": "^8.0.0",
    "eslint-config-next": "^16.2.2",
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5"
  }
