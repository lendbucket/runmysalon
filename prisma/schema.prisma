generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STYLIST
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         UserRole @default(STYLIST)
  locationId   String?
  inviteStatus String   @default("NOT_INVITED")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  location     Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)
  staffMember  StaffMember?
  accounts     Account[]
  sessions     Session[]
  @@map("users")
}

model Location {
  id               String @id @default(cuid())
  name             String
  squareLocationId String @unique
  address          String
  phone            String
  staffMembers     StaffMember[]
  inventoryItems   InventoryItem[]
  users            User[]
  schedules        Schedule[]
  @@map("locations")
}

model StaffMember {
  id                 String   @id @default(cuid())
  userId             String?  @unique
  locationId         String
  squareTeamMemberId String?  @unique
  fullName           String
  email              String?
  phone              String?
  position           String   @default("stylist")
  isActive           Boolean  @default(true)
  inviteStatus       String   @default("not_invited")
  createdAt          DateTime @default(now())
  location           Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  user               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts             Shift[]
  @@map("staff_members")
}

model InventoryItem {
  id               String   @id @default(cuid())
  locationId       String
  brand            String
  productName      String
  category         String
  shadeOrVolume    String?
  unitType         String?
  quantityOnHand   Float    @default(0)
  reorderThreshold Float    @default(2)
  costPerUnit      Float?
  ouncesPerUnit    Float?
  ouncesPerService Float?
  ouncesOnHand     Float?
  supplier         String?
  sku              String?
  expirationDate   DateTime?
  lastRestocked    DateTime?
  reorderQty       Int      @default(6)
  approvalStatus   String   @default("pending")
  isLowStock       Boolean  @default(false)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt
  location         Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  @@map("inventory_items")
}

model Schedule {
  id            String    @id @default(cuid())
  locationId    String
  weekStart     DateTime
  weekEnd       DateTime
  status        String    @default("draft")
  createdById   String
  submittedAt   DateTime?
  approvedAt    DateTime?
  approvedById  String?
  rejectedAt    DateTime?
  rejectionNote String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  shifts        Shift[]
  location      Location  @relation(fields: [locationId], references: [id])
  @@map("schedules")
}

model Shift {
  id            String      @id @default(cuid())
  scheduleId    String
  staffMemberId String
  date          DateTime
  startTime     String
  endTime       String
  isTimeOff     Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  schedule      Schedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id])
  @@map("shifts")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model AdminAlert {
  id        String   @id @default(cuid())
  title     String
  body      String
  severity  String   @default("info")
  createdAt DateTime @default(now())
  @@map("admin_alerts")
}
